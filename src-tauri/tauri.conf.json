{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Synapse Z",
  "version": "0.1.0",
  "identifier": "com.synapsez.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Synapse Z",
        "width": 450,
        "height": 600,
        "resizable": false,
        "decorations": false,
        "center": true,
        "transparent": true
      }
    ],

    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/synz.ico"
    ],
    "externalBin": [
      "binaries/luau-lsp"
    ]
  }
}
